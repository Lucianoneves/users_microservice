{
  "name": "users-microservice",
  "version": "2.1.0",
  "private": true,
  "description": "Monorepo — backend API (Express) e frontend (React)",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "test": "npm run test --prefix backend",
    "test:coverage": "npm run test:coverage --prefix backend",
    "typecheck": "npm run typecheck --prefix backend",
    "lint": "npm run lint --prefix backend"
  },
  "license": "MIT"
}
